# Copy this file to .env and fill in the values before running docker compose

# Required: MongoDB connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/courseconnect?retryWrites=true&w=majority

# Required: a strong random secret for signing JWTs
JWT_SECRET=change-me-to-a-strong-random-secret

# Optional overrides (defaults shown)
PORT=5050
JWT_EXPIRES_IN=7d
FRONTEND_ORIGIN=http://localhost
APP_PORT=80

# Set to "true" to seed the DB with demo courses/users on startup
# SEED_DATABASE=false
